# ─────────────────────────────────────────────
#         Auto-PPT Agent – Template Config
# ─────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────
# Google Gemini API key (free at aistudio.google.com/apikey)
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── MODEL SETTINGS (Optional) ─────────────────
# Gemini model to use as the agent brain
MODEL_ID=gemini-3.1-flash-lite-preview

# Max new tokens the model can generate per response
MAX_TOKENS=512

# Randomness: 0.0 = deterministic, 1.0 = creative
TEMPERATURE=0.2

# ── MEMORY / RAG SETTINGS (Optional) ──────────
# Where to store the vector memory (slide outlines, past searches)
VECTOR_STORE_PATH=./memory

# How many memory chunks to retrieve per query
K_RETRIEVAL=3

# ── AGENT BEHAVIOUR (Optional) ────────────────
# Max tool-call iterations before the agent gives up
AGENT_MAX_ITERATIONS=15

# Set to true to see every Thought / Action / Observation in terminal
AGENT_VERBOSE=true

# ── LOGGING (Optional) ────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── FILE SYSTEM (Optional) ────────────────────
# Folder where generated .pptx files are saved
AGENT_WORKSPACE=./workspace
